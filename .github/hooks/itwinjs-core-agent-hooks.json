{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "type": "command",
        "bash": "node .github/hooks/scripts/itwinjs-core-pre-tool-use.mjs",
        "cwd": ".",
        "timeoutSec": 30
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "node .github/hooks/scripts/itwinjs-core-post-tool-use.mjs",
        "cwd": ".",
        "timeoutSec": 10
      }
    ]
  }
}
