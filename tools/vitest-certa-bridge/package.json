{
  "name": "@itwin/vitest-certa-bridge",
  "version": "5.8.0-dev.6",
  "description": "Vitest BrowserProvider for running Electron renderer tests with backend callback support",
  "main": "lib/cjs/index.js",
  "module": "lib/esm/index.js",
  "typings": "lib/cjs/index",
  "typesVersions": {
    "*": {
      "electron-provider": [
        "lib/cjs/electron/provider.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./lib/cjs/index.d.ts",
      "import": "./lib/esm/index.js",
      "require": "./lib/cjs/index.js"
    },
    "./electron-provider": {
      "types": "./lib/cjs/electron/provider.d.ts",
      "import": "./lib/esm/electron/provider.js",
      "require": "./lib/cjs/electron/provider.js"
    }
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/iTwin/itwinjs-core.git",
    "directory": "tools/vitest-certa-bridge"
  },
  "scripts": {
    "build": "npm run -s build:cjs && npm run -s build:esm",
    "build:cjs": "tsc 1>&2 --outDir lib/cjs",
    "build:esm": "tsc 1>&2 --module ES2022 --outDir lib/esm && node -e \"require('fs').writeFileSync('lib/esm/package.json', JSON.stringify({type:'module'})+'\\n')\"",
    "clean": "rimraf -g lib",
    "cover": "",
    "docs": "",
    "lint": "eslint \"./src/**/*.ts\" 1>&2",
    "test": "vitest run --config src/test/vitest.config.mts",
    "test:electron-provider": "npm run -s build:test-fixtures && vitest run --config src/test/vitest.electron-provider.config.mts",
    "build:test-fixtures": "tsc -p tsconfig.test-fixtures.json 1>&2"
  },
  "devDependencies": {
    "@itwin/build-tools": "workspace:*",
    "@itwin/eslint-plugin": "^6.0.0",
    "@types/node": "~20.17.0",
    "@vitest/browser": "^3.0.6",
    "electron": "^41.0.0",
    "eslint": "^9.31.0",
    "rimraf": "^6.0.1",
    "typescript": "~5.6.2",
    "vitest": "^3.0.6"
  }
}
