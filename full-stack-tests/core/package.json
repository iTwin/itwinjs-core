{
  "name": "core-full-stack-tests",
  "//private": "NOTE: this is a private package that is never published",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "copy:config": "internal-tools copy-config",
    "copy:assets": "node scripts/copy-public-assets.js",
    "build": "tsc 1>&2 && npm run -s copy:assets",
    "clean": "rimraf -g lib .rush/temp/package-deps*.json coverage",
    "cover": "npm run -s test",
    "docs": "",
    "lint": "eslint \"./src/**/*.ts\" 1>&2",
    "lint-fix": "eslint --fix -f visualstudio \"./src/**/*.ts\" 1>&2",
    "lint-deprecation": "",
    "start:backend": "node lib/backend/BackendServer.js",
    "test": "cross-env DEBUG_LEAKS=true npm run -s test:chrome && npm run -s test:electron",
    "test:chrome": "vitest run",
    "test:electron": "cross-env VITEST_ELECTRON_GREP=\"#integration|#performance\" VITEST_ELECTRON_INVERT=true vitest run --config vitest.electron.config.mts",
    "debug:chrome": "vitest run --inspect-brk",
    "debug:electron": "vitest run --config vitest.electron.config.mts --inspect-brk",
    "test:integration": "npm run -s test:integration:chrome && npm run -s test:integration:electron",
    "test:integration:chrome": "vitest run --config vitest.integration.config.mts --testNamePattern \"#integration\"",
    "test:integration:electron": "cross-env VITEST_ELECTRON_GREP=\"#integration\" VITEST_ELECTRON_INVERT=false vitest run --config vitest.electron.config.mts",
    "test:performance": "npm run -s test:performance:chrome && npm run -s test:performance:electron",
    "test:performance:chrome": "vitest run --config vitest.integration.config.mts --testNamePattern \"#performance\"",
    "test:performance:electron": "cross-env VITEST_ELECTRON_GREP=\"#performance\" VITEST_ELECTRON_INVERT=false vitest run --config vitest.electron.config.mts"
  },
  "repository": {},
  "dependencies": {
    "@azure/storage-blob": "^12.28.0",
    "@itwin/browser-authorization": "^1.0.1",
    "@itwin/core-backend": "workspace:*",
    "@itwin/core-bentley": "workspace:*",
    "@itwin/core-common": "workspace:*",
    "@itwin/core-electron": "workspace:*",
    "@itwin/core-frontend": "workspace:*",
    "@itwin/core-i18n": "workspace:*",
    "@itwin/core-geometry": "workspace:*",
    "@itwin/core-markup": "workspace:*",
    "@itwin/core-quantity": "workspace:*",
    "@itwin/ecschema-metadata": "workspace:*",
    "@itwin/ecschema-rpcinterface-common": "workspace:*",
    "@itwin/ecschema-rpcinterface-impl": "workspace:*",
    "@itwin/ecsql-common": "workspace:*",
    "@itwin/editor-backend": "workspace:*",
    "@itwin/editor-common": "workspace:*",
    "@itwin/editor-frontend": "workspace:*",
    "@itwin/electron-authorization": "^0.22.3",
    "@itwin/express-server": "workspace:*",
    "@itwin/hypermodeling-frontend": "workspace:*",
    "@itwin/imodels-access-backend": "^6.0.2",
    "@itwin/imodels-access-frontend": "^6.0.2",
    "@itwin/imodels-client-authoring": "^6.0.2",
    "@itwin/imodels-client-management": "^6.0.2",
    "@itwin/object-storage-azure": "^3.0.4",
    "@itwin/reality-data-client": "^1.3.1",
    "azurite": "^3.35.0",
    "chai-as-promised": "^7.1.1",
    "chai": "^4.3.10",
    "electron": "^41.0.0",
    "fs-extra": "^8.1.0",
    "sinon-chai": "^3.7.0",
    "sinon": "^17.0.2"
  },
  "devDependencies": {
    "@itwin/build-tools": "workspace:*",
    "@itwin/certa": "workspace:*",
    "@itwin/eslint-plugin": "^6.0.0",
    "@itwin/itwins-client": "^1.6.1",
    "@itwin/object-storage-core": "^3.0.4",
    "@itwin/oidc-signin-tool": "^5.0.2",
    "@itwin/vitest-certa-bridge": "workspace:*",
    "@types/fs-extra": "^4.0.7",
    "@types/node": "~20.17.0",
    "@vitest/browser": "^3.0.6",
    "@loaders.gl/draco": "~4.3.4",
    "assert": "^2.0.0",
    "flatbuffers": "~1.12.0",
    "fuse.js": "^3.3.0",
    "i18next": "^21.9.1",
    "i18next-browser-languagedetector": "^6.1.2",
    "i18next-http-backend": "^3.0.2",
    "js-base64": "^3.6.1",
    "browserify-zlib": "^0.2.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "dotenv-expand": "^5.1.0",
    "eslint": "^9.31.0",
    "glob": "^10.5.0",
